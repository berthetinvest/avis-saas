---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { title, description, publishedAt, category } = article.data;

const categoryLabels: Record<string, string> = {
  'marketing-email': 'Marketing & Email',
  'rh-paie': 'RH & Paie',
  'gestion-projet': 'Gestion de projet',
  'guides-generaux': 'Guides',
};

const dateLabel = publishedAt.toLocaleDateString('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article class="group border-b border-ink-200 py-6 last:border-b-0">
  <a href={`/articles/${article.slug}`} class="block">
    <div class="flex items-center gap-3 text-xs text-ink-500">
      <span class="font-semibold uppercase tracking-wider text-accent">
        {categoryLabels[category]}
      </span>
      <span>·</span>
      <time datetime={publishedAt.toISOString()}>{dateLabel}</time>
    </div>
    <h3 class="mt-2 font-serif text-2xl font-bold text-ink-900 group-hover:text-accent transition-colors">
      {title}
    </h3>
    <p class="mt-2 text-ink-600">{description}</p>
    <p class="mt-3 text-sm font-semibold text-accent group-hover:text-accent-dark">
      Lire l'article →
    </p>
  </a>
</article>
