---
/**
 * JSON-LD schema.org/FAQPage.
 * Déclenche potentiellement le rich snippet FAQ dans les SERP Google.
 */
export interface Props {
  faq: Array<{ question: string; answer: string }>;
}

const { faq } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

{faq && faq.length > 0 && (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
)}
