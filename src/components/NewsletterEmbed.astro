---
/**
 * Embed Beehiiv — à configurer une fois ton compte créé.
 * Remplace la variable PUBLIC_BEEHIIV_PUBLICATION_ID dans .env
 */
const pubId = import.meta.env.PUBLIC_BEEHIIV_PUBLICATION_ID;
---

{pubId ? (
  <div class="my-10 rounded-md border border-ink-200 bg-ink-50 p-6">
    <h3 class="font-serif text-xl font-bold text-ink-900">
      La newsletter hebdo
    </h3>
    <p class="mt-2 text-sm text-ink-600">
      Un email chaque mardi : le meilleur outil testé de la semaine, un conseil
      concret pour votre stack SaaS, zéro blabla. Désinscription en un clic.
    </p>
    <iframe
      src={`https://embeds.beehiiv.com/${pubId}`}
      data-test-id="beehiiv-embed"
      width="100%"
      height="320"
      frameborder="0"
      scrolling="no"
      class="mt-4 rounded bg-white"
    ></iframe>
  </div>
) : (
  <div class="my-10 rounded-md border border-dashed border-ink-300 bg-ink-50/50 p-6 text-sm text-ink-500">
    <p class="font-semibold">Newsletter (à configurer)</p>
    <p class="mt-1">
      Ajoute <code>PUBLIC_BEEHIIV_PUBLICATION_ID</code> dans ton <code>.env</code>
      pour afficher le formulaire d'inscription Beehiiv ici.
    </p>
  </div>
)}
