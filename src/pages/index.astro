---
import BaseLayout from '@layouts/BaseLayout.astro';
import ArticleCard from '@components/ArticleCard.astro';
import NewsletterEmbed from '@components/NewsletterEmbed.astro';
import { getCollection } from 'astro:content';

const siteName = import.meta.env.PUBLIC_SITE_NAME || 'Avis SaaS';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 6);

const categories = [
  {
    slug: 'marketing-email',
    label: 'Marketing & Email',
    description: 'Brevo, Mailchimp, ActiveCampaign — quel outil email marketing pour votre PME ?',
  },
  {
    slug: 'rh-paie',
    label: 'RH & Paie',
    description: 'PayFit, Lucca, Personio — notre analyse des solutions RH pour TPE et PME.',
  },
  {
    slug: 'gestion-projet',
    label: 'Gestion de projet',
    description: 'Notion, ClickUp, Asana — comparatifs et cas d\'usage métier.',
  },
];
---

<BaseLayout
  title={`${siteName} — Le média indépendant des outils SaaS B2B pour TPE & PME`}
  description="Comparatifs, tests et avis tranchés sur les meilleurs outils SaaS pour votre entreprise. Marketing, RH, gestion de projet : on teste, on compare, on vous dit quoi choisir."
>
  <!-- Hero -->
  <section class="border-b border-ink-200 bg-ink-50/60">
    <div class="mx-auto max-w-wide px-4 py-16 md:px-6 md:py-24">
      <p class="text-sm font-semibold uppercase tracking-widest text-accent">
        Le média des outils SaaS pour TPE & PME
      </p>
      <h1 class="mt-4 max-w-4xl font-serif text-4xl font-bold leading-tight text-ink-900 md:text-6xl">
        On teste les outils SaaS B2B. <br class="hidden md:block" />
        <span class="text-accent">On vous dit ce qui marche vraiment.</span>
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-ink-700">
        Comparatifs rigoureux, avis sans langue de bois, prix vérifiés à jour.
        Notre job : vous faire économiser des heures de recherche et éviter les
        erreurs de choix qui coûtent cher.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/articles"
          class="inline-flex items-center gap-2 rounded-md bg-ink-900 px-5 py-3 text-sm font-semibold text-white hover:bg-ink-800"
        >
          Parcourir tous les comparatifs →
        </a>
        <a
          href="#newsletter"
          class="inline-flex items-center gap-2 rounded-md border border-ink-300 bg-white px-5 py-3 text-sm font-semibold text-ink-900 hover:border-accent hover:text-accent"
        >
          Recevoir la newsletter
        </a>
      </div>
    </div>
  </section>

  <!-- Catégories -->
  <section class="mx-auto max-w-wide px-4 py-16 md:px-6">
    <h2 class="font-serif text-3xl font-bold text-ink-900">Par catégorie</h2>
    <div class="mt-8 grid gap-6 md:grid-cols-3">
      {categories.map((cat) => (
        <a
          href={`/categories/${cat.slug}`}
          class="group block rounded-md border border-ink-200 bg-white p-6 hover:border-accent hover:shadow-sm transition-all"
        >
          <h3 class="font-serif text-xl font-bold text-ink-900 group-hover:text-accent">
            {cat.label}
          </h3>
          <p class="mt-2 text-sm text-ink-600">{cat.description}</p>
          <p class="mt-4 text-sm font-semibold text-accent">
            Voir les articles →
          </p>
        </a>
      ))}
    </div>
  </section>

  <!-- Derniers articles -->
  <section class="mx-auto max-w-wide px-4 pb-16 md:px-6">
    <div class="flex items-baseline justify-between">
      <h2 class="font-serif text-3xl font-bold text-ink-900">Les derniers articles</h2>
      <a href="/articles" class="text-sm font-semibold text-accent hover:text-accent-dark">
        Tout voir →
      </a>
    </div>
    {articles.length > 0 ? (
      <div class="mt-8 max-w-article">
        {articles.map((article) => <ArticleCard article={article} />)}
      </div>
    ) : (
      <p class="mt-8 text-ink-500">
        Les premiers articles arrivent. Revenez vite.
      </p>
    )}
  </section>

  <!-- Newsletter -->
  <section id="newsletter" class="mx-auto max-w-article px-4 md:px-6">
    <NewsletterEmbed />
  </section>
</BaseLayout>
