# Copier ce fichier en .env.local (non commité) et remplir avec tes valeurs
# Sur Vercel : ajouter ces mêmes variables dans Project Settings → Environment Variables

# URL canonique du site (sans trailing slash)
PUBLIC_SITE_URL=https://avis-saas.fr

# Nom du site (affiché dans header, footer, meta)
PUBLIC_SITE_NAME=Avis SaaS

# Google Analytics 4 — Measurement ID (format G-XXXXXXXXXX)
# Récupérable dans analytics.google.com → Admin → Data Streams
PUBLIC_GA4_ID=

# Beehiiv — ID de la publication pour l'embed newsletter
# Trouvable dans Beehiiv → Settings → API / Publication
PUBLIC_BEEHIIV_PUBLICATION_ID=

# Auteur principal (utilisé dans les articles et schema.org Person)
PUBLIC_AUTHOR_NAME=Mathieu Berthet
PUBLIC_AUTHOR_URL=https://avis-saas.fr/a-propos
